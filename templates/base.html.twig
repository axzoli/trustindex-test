<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Company Review App{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('review_index') }}">
            Company Review
        </a>

        <div class="navbar-nav">
            <a class="nav-link" href="{{ path('review_index') }}">
                Vélemények
            </a>
            <a class="nav-link" href="{{ path('review_new') }}">
                Új vélemény
            </a>
            <a class="nav-link" href="{{ path('company_statistics') }}">
                Cégek
            </a>
        </div>
    </div>
</nav>

<main class="container mb-5">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">
            {{ message }}
        </div>
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
